        target_content: "@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n  --font-serif: \"EB Garamond\", serif;\n  \n  --color-journal-primary: #002045;\n  --color-journal-secondary: #0061a5;\n  --color-journal-teal: #66affe;\n  --color-journal-bg: #faf9fd;\n  --color-journal-surface: #ffffff;\n  --color-journal-card-low: #f4f3f7;\n  --color-journal-text-dark: #1a1c1e;\n  --color-journal-text-muted: #43474e;\n  --color-journal-border: #c4c6cf;\n}\n\n/* Material Symbols Outlined Custom Configuration */\n.material-symbols-outlined {\n  font-family: \'Material Symbols Outlined\';\n  font-weight: normal;\n  font-style: normal;\n  font-size: 24px;\n  line-height: 1;\n  letter-spacing: normal;\n  text-transform: none;\n  display: inline-block;\n  white-space: nowrap;\n  word-wrap: normal;\n  direction: ltr;\n  -webkit-font-smoothing: antialiased;\n}\n\n/* Texture and details from design system */\n.paper-texture {\n  background-color: #faf9fd;\n  background-image: url(\"https://www.transparenttextures.com/patterns/soft-wallpaper.png\");\n  background-blend-mode: overlay;\n}\n\n.scrim-active {\n  background-color: rgba(0, 32, 69, 0.4);\n}\n\n.card-elevation-1 {\n  box-shadow: 0 4px 16px 0 rgba(0, 32, 69, 0.05);\n}\n\n.bottom-sheet-transition {\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.teal-accent-bar {\n  border-left: 4px solid #66affe;\n}\n\n/* Custom scrollbar to match high-end UI */\n::-webkit-scrollbar {\n  width: 6px;\n}\n::-webkit-scrollbar-track {\n  background: transparent;\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(0, 32, 69, 0.1);\n  border-radius: 99px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(0, 32, 69, 0.2);\n}"
