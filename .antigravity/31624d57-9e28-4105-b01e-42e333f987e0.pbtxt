ter text-teal-500 font-bold text-lg\\\">K</div>\\n        <div>\\n          <p class=\\\"text-sm font-bold text-slate-800\\\">Kyoto Temples</p>\\n          <p class=\\\"text-[11px] text-slate-400\\\">Japan &bull; 8 Destinations</p>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <!-- Bottom Nav -->\\n    <div class=\\\"h-20 w-full border-t border-slate-100 flex items-center justify-around px-4\\\">\\n      <div class=\\\"w-10 h-10 bg-rose-500 rounded-2xl flex items-center justify-center shadow-lg shadow-rose-200\\\">\\n        <div class=\\\"w-4 h-4 bg-white rounded-sm\\\"></div>\\n      </div>\\n      <div class=\\\"w-10 h-10 rounded-2xl flex items-center justify-center\\\">\\n        <div class=\\\"w-4 h-4 bg-slate-300 rounded-full\\\"></div>\\n      </div>\\n      <div class=\\\"w-10 h-10 rounded-2xl flex items-center justify-center\\\">\\n        <div class=\\\"w-4 h-4 border-2 border-slate-300 rounded-full\\\"></div>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <!-- Device 2: Analytics/Health -->\\n  <div class=\\\"w-[290px] h-[600px] bg-slate-950 rounded-[3.5rem] border-[10px] border-[#1E293B] shadow-2xl relative overflow-hidden flex flex-col\\\">\\n    <div class=\\\"h-8 w-full flex items-center justify-between px-8 pt-4 pb-2\\\">\\n      <span class=\\\"text-[11px] font-bold text-white\\\">10:22</span>\\n      <div class=\\\"flex gap-1.5\\\">\\n        <div class=\\\"w-3 h-3 rounded-full bg-emerald-400\\\"></div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"px-6 py-6\\\">\\n      <div class=\\\"flex justify-between items-center\\\">\\n        <h1 class=\\\"text-2xl font-black text-white\\\">Stats</h1>\\n        <div class=\\\"w-10 h-10 rounded-full bg-slate-800 border border-slate-700\\\"></div>\\n      </div>\\n    </div>\\n\\n    <!-- Ring Chart Area -->\\n    <div class=\\\"flex-1 flex flex-col items-center justify-center gap-8\\\">\\n      <div class=\\\"relative w-40 h-40 flex items-center justify-center\\\">\\n        <div class=\\\"absol