  file_change {
    absolute_path_uri: "file:///src/components/AISummarySheet.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \"react\";\nimport { AISummary } from \"../types\";\n\ninterface AISummarySheetProps {\n  isOpen: boolean;\n  onClose: () => void;\n  summary: AISummary | null;\n  dateText: string;\n  isLoading: boolean;\n  onRefine: (instruction: string) => void;\n}\n\nexport default function AISummarySheet({\n  isOpen,\n  onClose,\n  summary,\n  dateText,\n  isLoading,\n  onRefine,\n}: AISummarySheetProps) {\n  const [copied, setCopied] = useState(false);\n  const [showRefineInput, setShowRefineInput] = useState(false);\n  const [refineText, setRefineText] = useState(\"\");\n  const [showShareModal, setShowShareModal] = useState(false);\n\n  if (!isOpen) return null;\n\n  const handleCopy = () => {\n    if (!summary) return;\n    const textToCopy = `Ethereal Journal AI Summary - ${dateText}\n\nMILESTONES:\n${summary.milestones.map((m) => `- ${m}`).join(\"\\n\")}\n\nACTIONABLE VECTORS:\n${summary.actionableVectors.map((v) => `- ${v}`).join(\"\\n\")}\n\nEMOTIONAL TONE:\n${summary.emotionalTone.map((t) => `- ${t}`).join(\"\\n\")}\n`;\n    navigator.clipboard.writeText(textToCopy);\n    setCopied(true);\n    setTimeout(() => setCopied(false), 2000);\n  };\n\n  const submitRefine = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!refineText.trim()) return;\n    onRefine(refineText);\n    setRefineText(\"\");\n    setShowRefineInput(false);\n  };\n\n  return (\n    <>\n      {/* Scrim Overlay */}\n      <div \n        id=\"summary-scrim\"\n        onClick={onClose}\n        className=\"absolute inset-0 z-[60] bg-journal-primary/30 backdrop-blur-[2px] transition-opacity duration-300 animate-fade-in\"\n      />\n\n      {/* Elevated Bottom Sheet */}\n      <div \n        id=\"summary-bottom-sheet\"\n        className=\"absolute inset-x-0 bottom-0 z-[70] max-w-[840px] mx-auto bg-journal-surface rounded-t-[32px] shadow-2xl flex flex-col max-h-[85%] bottom-sheet-transition translate-y-0 animate-slide-up\"\n      >\n        {/* Drag Handle */}\n        <div className=\"w-full flex justify-center pt-3 pb-1 cursor-pointer shrink-0\" onClick={onClose}>\n          <div className=\"w-10 h-1.5 bg-slate-300 rounded-full\" />\n        </div>\n\n        {/* Header */}\n        <div className=\"px-6 py-3 flex justify-between items-center border-b border-slate-100 shrink-0\">\n          <h2 className=\"font-serif text-xl md:text-2xl font-bold text-journal-primary\">\n            {isLoading ? \"Consulting AI...\" : `AI Summary for ${dateText}`}\n          </h2>\n          <button \n            id=\"close-summary-sheet\"\n            onClick={onClose}\n            className=\"p-1.5 hover:bg-slate-100 rounded-full transition-colors active:scale-95 cursor-pointer\"\n          >\n            <span className=\"material-symbols-outlined text-journal-text-muted\">close</span>\n          </button>\n        </div>\n\n        {/* Content Area */}\n        <div className=\"flex-1 overflow-y-auto px-6 py-4 space-y-6\">\n          {isLoading ? (\n            /* Loading State */\n            <div className=\"py-12 flex flex-col items-center justify-center space-y-6 text-center\">\n              <div className=\"relative flex items-center justify-center\">\n                {/* Custom glowing rotating loader */}\n                <div className=\"w-16 h-16 rounded-full border-4 border-journal-teal/20 border-t-journal-primary animate-spin\" />\n                <span className=\"material-symbols-outlined text-journal-primary absolute animate-pulse !text-[28px]\">\n                  auto_awesome\n                </span>\n              </div>\n              <div className=\"space-y-2\">\n                <p className=\"font-serif text-lg text-journal-primary italic\">\"Synthesizing the landscape of your day...\"</p>\n                <p className=\"text-xs text-journal-text-muted animate-pulse\">Reading reflections, mapping emotions, and compiling vectors</p>\n              </div>\n            </div>\n          ) : !summary ? (\n            /* Error / Empty State fallback */\n            <div className=\"py-12 text-center text-journal-text-muted\">\n              <span className=\"material-symbols-outlined !text-[48px] text-slate-300\">error</span>\n              <p className=\"font-serif text-lg text-journal-primary mt-2\">Could not generate summary</p>\n              <p className=\"text-sm\">Ensure you have logged some thoughts for today first.</p>\n            </div>\n          ) : (\n            /* Loaded State matching exact UI */\n            <>\n              {/* Atmospheric Visual (Auroral/Gradients mapping current mood) */}\n              <div className=\"relative w-full h-32 md:h-36 rounded-2xl overflow-hidden mb-2 bg-gradient-to-r from-teal-50 via-indigo-50 to-amber-50 border border-slate-200/50 flex items-center justify-center p-4\">\n                <div className=\"absolute inset-0 bg-gradient-to-t from-journal-surface/40 via-transparent to-transparent\" />\n                \n                {/* Absolute center graphic details */}\n                <div className=\"flex items-center gap-4 relative z-10\">\n                  <div className=\"w-12 h-12 rounded-full bg-journal-surface/80 shadow-sm flex items-center justify-center animate-pulse\">\n                    <span className=\"material-symbols-outlined text-journal-primary\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                      psychology\n                    </span>\n                  </div>\n                  <div className=\"text-left\">\n                    <p className=\"text-xs uppercase tracking-widest text-journal-primary font-bold\">Confidant Reflection</p>\n                    <p className=\"font-serif text-sm italic text-journal-text-dark font-medium\">Daily emotional vectors stabilized</p>\n                  </div>\n                </div>\n\n                <div className=\"absolute bottom-3 left-3 z-10\">\n                  <span className=\"px-3 py-1 bg-journal-primary text-journal-surface rounded-full text-[10px] font-bold uppercase tracking-wider\">\n                    DEEP INSIGHT\n                  </span>\n                </div>\n              </div>\n\n              {/* Thematic Breakdown */}\n              <div className=\"space-y-5\">\n                \n                {/* 1. Milestones */}\n                <div className=\"teal-accent-bar pl-4 py-2 space-y-2 bg-journal-card-low/40 rounded-r-2xl border border-l-0 border-slate-100\">\n                  <div className=\"flex items-center gap-2 text-journal-primary font-bold\">\n                    <span className=\"material-symbols-outlined\">auto_awesome</span>\n                    <h3 className=\"font-serif text-lg font-bold\">Milestones</h3>\n                  </div>\n                  <ul className=\"list-disc list-inside text-journal-text-muted font-sans text-sm leading-relaxed space-y-1.5 pl-1\">\n                    {summary.milestones.map((milestone, idx) => (\n                      <li key={idx} className=\"marker:text-journal-teal\">{milestone}</li>\n                    ))}\n                  </ul>\n                </div>\n\n                {/* 2. Actionable Vectors */}\n                <div className=\"teal-accent-bar pl-4 py-2 space-y-2 bg-journal-card-low/40 rounded-r-2xl border border-l-0 border-slate-100\">\n                  <div className=\"flex items-center gap-2 text-journal-primary font-bold\">\n                    <span className=\"material-symbols-outlined\">trending_up</span>\n                    <h3 className=\"font-serif text-lg font-bold\">Actionable Vectors</h3>\n                  </div>\n                  <ul className=\"list-disc list-inside text-journal-text-muted font-sans text-sm leading-relaxed space-y-1.5 pl-1\">\n                    {summary.actionableVectors.map((vector, idx) => (\n                      <li key={idx} className=\"marker:text-journal-primary\">{vector}</li>\n                    ))}\n                  </ul>\n                </div>\n\n                {/* 3. Emotional Tone */}\n                <div className=\"teal-accent-bar pl-4 py-2 space-y-2 bg-journal-card-low/40 rounded-r-2xl border border-l-0 border-slate-100\">\n                  <div className=\"flex items-center gap-2 text-journal-primary font-bold\">\n                    <span className=\"material-symbols-outlined\">sentiment_satisfied</span>\n                    <h3 className=\"font-serif text-lg font-bold\">Emotional Tone</h3>\n                  </div>\n                  <ul className=\"list-disc list-inside text-journal-text-muted font-sans text-sm leading-relaxed space-y-1.5 pl-1\">\n                    {summary.emotionalTone.map((tone, idx) => (\n                      <li key={idx} className=\"marker:text-amber-500\">{tone}</li>\n                    ))}\n                  </ul>\n                </div>\n\n              </div>\n            </>\n          )}\n        </div>\n\n        {/* Refine prompt inline form */}\n        {showRefineInput && (\n          <form onSubmit={submitRefine} className=\"px-6 py-3 bg-slate-50 border-t border-slate-100 flex gap-2 items-center animate-fade-in shrink-0\">\n            <input \n              id=\"refine-text-input\"\n              type=\"text\" \n              placeholder=\"How would you like to refine this summary? (e.g. \'be more poetic\')\"\n              value={refineText}\n              onChange={(e) => setRefineText(e.target.value)}\n              className=\"flex-1 bg-white border border-slate-200 rounded-full px-4 py-2 text-sm text-journal-text-dark focus:outline-none focus:border-journal-primary focus:ring-1 focus:ring-journal-primary font-sans\"\n              autoFocus\n            />\n            <button \n              id=\"submit-refine-button\"\n              type=\"submit\"\n              className=\"px-4 py-2 bg-journal-primary text-white rounded-full text-xs font-semibold cursor-pointer active:scale-95 transition-transform\"\n            >\n              Send\n            </button>\n            <button \n              type=\"button\"\n              onClick={() => setShowRefineInput(false)}\n              className=\"p-1 hover:bg-slate-200 rounded-full cursor-pointer\"\n            >\n              <span className=\"material-symbols-outlined text-xs\">close</span>\n            </button>\n          </form>\n        )}\n\n        {/* Footer / Feedback Chips */}\n        <div className=\"p-4 bg-journal-surface border-t border-slate-100 shrink-0 select-none\">\n          <div className=\"flex flex-wrap gap-2.5 justify-start\">\n            <button \n              id=\"refine-summary-btn\"\n              onClick={() => setShowRefineInput(!showRefineInput)}\n              className=\"flex items-center gap-1.5 px-3.5 py-2 border border-journal-primary/20 rounded-full text-xs font-bold text-journal-primary hover:bg-journal-card-low transition-colors active:scale-95 cursor-pointer\"\n            >\n              <span className=\"material-symbols-outlined !text-[16px]\">tune</span>\n              Refine Summary\n            </button>\n\n            <button \n              id=\"copy-summary-btn\"\n              onClick={handleCopy}\n              className=\"flex items-center gap-1.5 px-3.5 py-2 border border-journal-primary/20 rounded-full text-xs font-bold text-journal-primary hover:bg-journal-card-low transition-colors active:scale-95 cursor-pointer\"\n            >\n              <span className=\"material-symbols-outlined !text-[16px]\">\n                {copied ? \"check\" : \"content_copy\"}\n              </span>\n              {copied ? \"Copied\" : \"Copy to Clipboard\"}\n            </button>\n\n            <button \n              id=\"share-summary-btn\"\n              onClick={() => setShowShareModal(true)}\n              className=\"flex items-center gap-1.5 px-3.5 py-2 border border-journal-primary/20 rounded-full text-xs font-bold text-journal-primary hover:bg-journal-card-low transition-colors active:scale-95 cursor-pointer\"\n            >\n              <span className=\"material-symbols-outlined !text-[16px]\">ios_share</span>\n              Share Log\n            </button>\n          </div>\n        </div>\n      </div>\n\n      {/* Simulated Share Dialog */}\n      {showShareModal && (\n        <div className=\"absolute inset-0 bg-black/50 z-[80] flex items-end justify-center\">\n          <div className=\"w-full bg-slate-900 text-white rounded-t-[28px] p-6 space-y-6\">\n            <div className=\"flex justify-between items-center\">\n              <h4 className=\"font-semibold text-sm tracking-wider uppercase opacity-80\">Share with Ethereal Hub</h4>\n              <button onClick={() => setShowShareModal(false)}>\n                <span className=\"material-symbols-outlined text-white/60\">close</span>\n              </button>\n            </div>\n            \n            <div className=\"grid grid-cols-4 gap-4 text-center\">\n              <div className=\"flex flex-col items-center gap-2 cursor-pointer\" onClick={() => setShowShareModal(false)}>\n                <div className=\"w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center\">\n                  <span className=\"material-symbols-outlined\">chat</span>\n                </div>\n                <span className=\"text-xs opacity-80\">Messages</span>\n              </div>\n              <div className=\"flex flex-col items-center gap-2 cursor-pointer\" onClick={() => setShowShareModal(false)}>\n                <div className=\"w-12 h-12 rounded-full bg-green-600 flex items-center justify-center\">\n                  <span className=\"material-symbols-outlined\">mail</span>\n                </div>\n                <span className=\"text-xs opacity-80\">Gmail</span>\n              </div>\n              <div className=\"flex flex-col items-center gap-2 cursor-pointer\" onClick={() => setShowShareModal(false)}>\n                <div className=\"w-12 h-12 rounded-full bg-sky-500 flex items-center justify-center\">\n                  <span className=\"material-symbols-outlined\">cloud_upload</span>\n                </div>\n                <span className=\"text-xs opacity-80\">Drive</span>\n              </div>\n              <div className=\"flex flex-col items-center gap-2 cursor-pointer\" onClick={() => setShowShareModal(false)}>\n                <div className=\"w-12 h-12 rounded-full bg-slate-700 flex items-center justify-center\">\n                  <span className=\"material-symbols-outlined\">link</span>\n                </div>\n                <span className=\"text-xs opacity-80\">Copy Link</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n    </>\n  );\n}\n"
    }
