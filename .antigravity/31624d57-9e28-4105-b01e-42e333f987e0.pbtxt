        target_content: "        {/* Dynamic New Entry Panel */}\n        <div className=\"bg-white rounded-2xl p-4 card-elevation-1 border border-slate-100 space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-slate-100 pb-2\">\n            <h3 className=\"font-serif text-base font-bold text-journal-primary\">Record Reflection</h3>\n            <div className=\"flex items-center gap-1.5\">\n              <button \n                id=\"toggle-voice-btn\"\n                onClick={() => {\n                  setIsVoiceActive(!isVoiceActive);\n                  setNewText(\"\");\n                }}\n                className={`flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold transition-all cursor-pointer ${\n                  isVoiceActive \n                    ? \"bg-journal-primary text-white\" \n                    : \"bg-slate-100 text-journal-text-muted hover:bg-slate-200\"\n                }`}\n              >\n                <span className=\"material-symbols-outlined !text-[14px]\">mic</span>\n                Voice Entry\n              </button>\n            </div>\n          </div>\n\n          {!isVoiceActive ? (\n            /* Traditional Text Entry */\n            <div className=\"space-y-4\">\n              <textarea\n                id=\"entry-textarea\"\n                rows={3}\n                placeholder=\"What is occupying your thoughts today?\"\n                value={newText}\n                onChange={(e) => setNewText(e.target.value)}\n                className=\"w-full text-sm text-journal-text-dark placeholder-slate-400 bg-slate-50/50 p-3 rounded-xl border border-slate-100 focus:outline-none focus:border-journal-primary focus:bg-white transition-all font-sans\"\n              />"
