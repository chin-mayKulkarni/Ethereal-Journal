    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n  --font-serif: \"EB Garamond\", serif;\n  \n  --color-journal-primary: #002045;\n  --color-journal-secondary: #0061a5;\n  --color-journal-teal: #66affe;\n  --color-journal-bg: #faf9fd;\n  --color-journal-surface: #ffffff;\n  --color-journal-card-low: #f4f3f7;\n  --color-journal-text-dark: #1a1c1e;\n  --color-journal-text-muted: #43474e;\n  --color-journal-border: #c4c6cf;\n}\n\n/* Material Symbols Outlined Custom Configuration */\n.material-symbols-outlined {\n  font-family: \'Material Symbols Outlined\';\n  font-weight: normal;\n  font-style: normal;\n  font-size: 24px;\n  line-height: 1;\n  letter-spacing: normal;\n  text-transform: none;\n  display: inline-block;\n  white-space: nowrap;\n  word-wrap: normal;\n  direction: ltr;\n  -webkit-font-smoothing: antialiased;\n}\n\n/* Texture and details from design system */\n.paper-texture {\n  background-color: #faf9fd;\n  background-image: url(\"https://www.transparenttextures.com/patterns/soft-wallpaper.png\");\n  background-blend-mode: overlay;\n}\n\n.scrim-active {\n  background-color: rgba(0, 32, 69, 0.4);\n}\n\n.card-elevation-1 {\n  box-shadow: 0 4px 16px 0 rgba(0, 32, 69, 0.05);\n}\n\n.bottom-sheet-transition {\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.teal-accent-bar {\n  border-left: 4px solid #66affe;\n}\n\n/* Custom scrollbar to match high-end UI */\n::-webkit-scrollbar {\n  width: 6px;\n}\n::-webkit-scrollbar-track {\n  background: transparent;\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(0, 32, 69, 0.1);\n  border-radius: 99px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(0, 32, 69, 0.2);\n}"
      replacement_content: "@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n  --font-serif: \"EB Garamond\", serif;\n  \n  --color-journal-primary: #1e293b;\n  --color-journal-secondary: #f43f5e;\n  --color-journal-teal: #6366f1;\n  --color-journal-bg: #fdfcfb;\n  --color-journal-surface: #ffffff;\n  --color-journal-card-low: #f1f5f9;\n  --color-journal-text-dark: #0f172a;\n  --color-journal-text-muted: #64748b;\n  --color-journal-border: #e2e8f0;\n}\n\n/* Material Symbols Outlined Custom Configuration */\n.material-symbols-outlined {\n  font-family: \'Material Symbols Outlined\';\n  font-weight: normal;\n  font-style: normal;\n  font-size: 24px;\n  line-height: 1;\n  letter-spacing: normal;\n  text-transform: none;\n  display: inline-block;\n  white-space: nowrap;\n  word-wrap: normal;\n  direction: ltr;\n  -webkit-font-smoothing: antialiased;\n}\n\n/* Texture and details from Vibrant Palette design system */\n.paper-texture {\n  background-color: #fdfcfb;\n  background-image: radial-gradient(rgba(15, 23, 42, 0.03) 1px, transparent 0);\n  background-size: 20px 20px;\n}\n\n.scrim-active {\n  background-color: rgba(15, 23, 42, 0.3);\n}\n\n.card-elevation-1 {\n  box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.05), 0 8px 10px -6px rgba(99, 102, 241, 0.05);\n}\n\n.bottom-sheet-transition {\n  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.teal-accent-bar {\n  border-left: 4px solid #f43f5e; /* Rose 500 */\n}\n\n/* Custom scrollbar to match high-end UI */\n::-webkit-scrollbar {\n  width: 6px;\n}\n::-webkit-scrollbar-track {\n  background: transparent;\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(15, 23, 42, 0.1);\n  border-radius: 99px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(15, 23, 42, 0.2);\n}"
    }
